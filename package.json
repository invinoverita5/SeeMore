{
  "name": "chessinsights",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm --workspace @chessinsights/web run build",
    "db:validate": "npm --workspace @chessinsights/db run prisma:validate",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && npm --workspace @chessinsights/web run typecheck",
    "test": "vitest run"
  },
  "overrides": {
    "next@^16.2.4": {
      "postcss": "8.5.12"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.19.39",
    "eslint": "^10.2.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
